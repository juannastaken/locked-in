{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Locked In",
  "version": "0.12.1",
  "identifier": "dev.lockedin.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Locked In",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#0a0a0b",
        "backgroundThrottling": "disabled"
      },
      {
        "label": "overlay",
        "title": "Locked In Overlay",
        "width": 240,
        "height": 72,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      },
      {
        "label": "blocker",
        "title": "Locked In",
        "fullscreen": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "backgroundThrottling": "disabled"
      },
      {
        "label": "popup",
        "title": "Locked In Check-in",
        "width": 380,
        "height": 270,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": false,
        "backgroundThrottling": "disabled"
      },
      {
        "label": "refboard",
        "title": "Locked In Refs",
        "width": 560,
        "height": 420,
        "minWidth": 280,
        "minHeight": 220,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCONFIG/refboard/*"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzM0E1RjRBMkUyRkM1NzcKUldSM3hTOHVTbDg2VTBoWVhtbktkdDA4di9PNldPYm44eDRUTXBrdHEyS3l6MkVEc2tSWjZERisK",
      "endpoints": [
        "https://raw.githubusercontent.com/juannastaken/locked-in/main/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
